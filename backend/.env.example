PORT=3001
FRONTEND_URL=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# Storage: either Cloudflare R2 or AWS S3.
# R2:  set R2_ENDPOINT_URL + R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY, R2_REGION="auto".
# AWS: leave R2_ENDPOINT_URL unset, set R2_REGION (e.g. ap-southeast-2).
#      In ECS, omit the access keys to use the task role; locally, use a dev IAM user's keys.
R2_BUCKET_NAME=mike
R2_REGION=ap-southeast-2
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENROUTER_API_KEY=your-openrouter-key
RESEND_API_KEY=your-resend-key
